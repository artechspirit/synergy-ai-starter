{
  "extends": "@repo/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@repo/ui": ["../../packages/ui/src/web/index.ts"],
      "@repo/ui/web": ["../../packages/ui/src/web/index.ts"],
      "@repo/validation": ["../../packages/validation/src/index.ts"],
      "@repo/env": ["../../packages/env/src/web.ts"],
      "@repo/api-contracts": ["../../packages/api-contracts/src/index.ts"],
      "@repo/translations": ["../../packages/translations/src/index.ts"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
