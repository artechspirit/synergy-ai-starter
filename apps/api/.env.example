# apps/api Environment Variables
# Copy this to .env and fill in the values

# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────
# Local: use docker-compose (docker compose up -d)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/synergy_dev?schema=public"

# ─── JWT RS256 Keys ────────────────────────────────────────────────────────
# Generate with: node scripts/generate-keys.mjs
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_YOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Redis (optional — for BullMQ) ────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
